{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f",
    "test": "bun run test:games && bun run test:wallets",
    "test:games": "cd services/games && bun test",
    "test:wallets": "cd services/wallets && bun test"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
